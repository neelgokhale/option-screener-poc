# Market data (Finnhub - free tier: 60 calls/min)
FINNHUB_API_KEY=

# Email alerts (Resend - free tier: 3000 emails/month)
RESEND_API_KEY=
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=screener@option-screener.dev

# Dashboard URL (used in email links)
DASHBOARD_URL=http://localhost:3000

# Database (Railway: use persistent volume path)
DB_PATH=data/screener.db

# Screening
MAX_TRADES=15
SCAN_CACHE_TTL_SECONDS=3600

# s3 env vars (backtesting backups)
S3_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
BACKUP_RETENTION_DAYS=
